#Graphviz format for a FMS class

digraph "CNC" {
  # list of states
  init [peripheries = 2]
  idle
  load_block
  rapid_motion
  interp_motion
  no_motion
  stop [peripheries = 2]
  go_to_zero

  # list of transition
  init -> idle
  init -> stop
  idle -> idle
  idle -> load_block [label="reset"] 

  load_block -> no_motion
  no_motion -> load_block

  load_block -> rapid_motion [label="begin_rapid"]
  rapid_motion -> rapid_motion
  rapid_motion -> load_block [label="end_rapid"]

  load_block -> interp_motion [label="begin_interp"]
  interp_motion -> interp_motion
  interp_motion -> load_block [label="end_interp"]

  load_block -> idle

  idle -> stop

  idle -> go_to_zero 
  go_to_zero -> go_to_zero [label="begin_rapid"]
  go_to_zero -> idle [label="end_rapid"]
} 