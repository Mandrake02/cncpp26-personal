# Doxyfile for examples_3_AI / Vector2D

PROJECT_NAME           = "Vector2D Example"
PROJECT_BRIEF          = "Documentazione API per la classe Vector2D"
PROJECT_NUMBER         = "1.0"
OUTPUT_DIRECTORY       = docs

# Input
INPUT                  = Vector2D.h Vector2D.cpp example_3.cpp
FILE_PATTERNS          = *.h *.hpp *.c *.cc *.cpp
RECURSIVE              = NO
EXCLUDE                =

# Extraction behavior
EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO
EXTRACT_LOCAL_CLASSES  = YES
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO

# Parsing / source browsing
JAVADOC_AUTOBRIEF      = NO
QT_AUTOBRIEF           = NO
MULTILINE_CPP_IS_BRIEF = NO
MARKDOWN_SUPPORT       = YES
INLINE_SOURCES         = NO
SOURCE_BROWSER         = YES
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES

# Warnings
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = YES

# Output formats
GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_LATEX         = NO
GENERATE_MAN           = NO
GENERATE_RTF           = NO
GENERATE_XML           = NO
GENERATE_DOCBOOK       = NO

# Graphs (keep simple / portable)
HAVE_DOT               = NO

# Optimization for C++
OPTIMIZE_OUTPUT_FOR_C  = NO
BUILTIN_STL_SUPPORT    = YES
